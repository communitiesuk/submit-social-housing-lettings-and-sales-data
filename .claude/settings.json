      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(echo:*)",
      "Bash(cat:*)",
      "Bash(tail:*)",
      "Bash(head:*)",
      "Bash(gh:*)",
      "Bash(git add .)",
      "Bash(git add --all)",
      "Bash(git add -A)",
      "Bash(git push --force)",
      "Bash(git push --force-with-lease)",
