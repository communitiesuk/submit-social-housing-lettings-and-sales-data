      "Bash(yarn stylelint:*)",
      "Bash(yarn build:*)",
      "Bash(git fetch)",
      "Bash(git pull)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Edit(app/**)",
      "Edit(config/**)",
      "Edit(db/migrate/**)",
      "Edit(lib/**)",
      "Edit(spec/**)",
      "Edit(docs/**)"
